<style>
    .premium-page-title { margin-bottom: 0.4rem; }
    .premium-page-sub { color: var(--text-secondary); margin-bottom: 2rem; }

    .premium-lock {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        margin-top: 2rem;
    }
    .premium-lock-icon {
        font-size: 3.5rem;
        margin-bottom: 1.25rem;
        background: linear-gradient(135deg, #a855f7, #6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
    }
    .premium-lock h2 { font-size: 1.5rem; margin-bottom: 0.6rem; }
    .premium-lock p { color: var(--text-secondary); max-width: 480px; margin: 0 auto 1.75rem; }

    .pdf-filters {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
        align-items: center;
    }
    .pdf-filter-select {
        padding: 0.45rem 0.9rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 0.9rem;
        cursor: pointer;
    }
    .pdf-filter-select:focus { outline: none; border-color: var(--accent); }

    .pdf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
    .pdf-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        transition: border-color 0.15s;
    }
    .pdf-card:hover { border-color: var(--accent); }

    .pdf-icon {
        flex-shrink: 0;
        width: 48px;
        height: 56px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
        box-shadow: 0 2px 8px rgba(239,68,68,0.3);
    }
    .pdf-body { flex: 1; min-width: 0; }
    .pdf-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pdf-desc { font-size: 0.82rem; color: var(--text-secondary); margin-bottom: 0.6rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .pdf-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.75rem; }
    .pdf-tag {
        font-size: 0.72rem;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 600;
    }
    .pdf-tag-cat { background: rgba(99,102,241,0.15); color: var(--accent); }
    .pdf-tag-course { background: rgba(16,185,129,0.15); color: #10b981; }
    .pdf-tag-module { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .pdf-meta { font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 0.75rem; }
    .pdf-meta span { margin-right: 0.5rem; }
    .pdf-dl-btn { width: 100%; }

    .pdf-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-secondary);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        grid-column: 1/-1;
    }
    .pdf-empty i { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
</style>

<div>
    <h1 class="premium-page-title"><i class="fas fa-file-pdf me-2" style="color:#ef4444;"></i>Шаблоны и чек-листы</h1>
    <p class="premium-page-sub">PDF-материалы для курсов: шаблоны, чек-листы, конспекты</p>

    <% if (messages && messages.success) { %><div class="alert alert-success"><%= messages.success %></div><% } %>
    <% if (messages && messages.error) { %><div class="alert alert-danger"><%= messages.error %></div><% } %>

    <% if (!hasAccess) { %>
        <div class="premium-lock">
            <i class="fas fa-file-pdf premium-lock-icon"></i>
            <h2>Шаблоны и чек-листы — функция Premium</h2>
            <p>Готовые PDF-шаблоны, чек-листы и конспекты по курсам доступны только по подписке.</p>
            <a href="/auth/profile" class="btn btn-primary">Получить Premium</a>
        </div>
    <% } else { %>

        <%# Filters %>
        <form method="GET" action="/premium/pdfs" class="pdf-filters">
            <div>
                <select name="category" class="pdf-filter-select" onchange="this.form.submit()">
                    <option value="all" <%= currentCategory === 'all' ? 'selected' : '' %>>Все категории</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>><%= cat %></option>
                    <% }) %>
                </select>
            </div>
            <% if (courses.length > 0) { %>
            <div>
                <select name="courseId" class="pdf-filter-select" onchange="this.form.submit()">
                    <option value="all" <%= currentCourse === 'all' ? 'selected' : '' %>>Все курсы</option>
                    <% courses.forEach(course => { %>
                        <option value="<%= course.id %>" <%= String(currentCourse) === String(course.id) ? 'selected' : '' %>><%= course.title %></option>
                    <% }) %>
                </select>
            </div>
            <% } %>
            <span style="color:var(--text-secondary); font-size:0.85rem; margin-left:auto;">
                Всего: <strong style="color:var(--text-primary);"><%= total %></strong>
            </span>
        </form>

        <div class="pdf-grid">
            <% if (materials.length === 0) { %>
                <div class="pdf-empty">
                    <i class="fas fa-folder-open"></i>
                    <h3>Материалов пока нет</h3>
                    <p>По выбранным фильтрам ничего не найдено.</p>
                    <a href="/premium/pdfs" class="btn btn-outline" style="margin-top:0.5rem;">Сбросить фильтры</a>
                </div>
            <% } else { %>
                <% materials.forEach(mat => { %>
                    <div class="pdf-card">
                        <div class="pdf-icon"><i class="fas fa-file-pdf"></i></div>
                        <div class="pdf-body">
                            <div class="pdf-title" title="<%= mat.title %>"><%= mat.title %></div>
                            <% if (mat.description) { %>
                                <div class="pdf-desc"><%= mat.description %></div>
                            <% } %>
                            <div class="pdf-tags">
                                <% if (mat.category) { %><span class="pdf-tag pdf-tag-cat"><i class="fas fa-tag me-1"></i><%= mat.category %></span><% } %>
                                <% if (mat.Course) { %><span class="pdf-tag pdf-tag-course"><i class="fas fa-book me-1"></i><%= mat.Course.title %></span><% } %>
                                <% if (mat.module) { %><span class="pdf-tag pdf-tag-module"><i class="fas fa-layer-group me-1"></i><%= mat.module %></span><% } %>
                            </div>
                            <div class="pdf-meta">
                                <% if (mat.fileSize) { %><span><i class="fas fa-weight-hanging me-1"></i><%= formatFileSize(mat.fileSize) %></span><% } %>
                                <span><i class="fas fa-download me-1"></i><%= mat.downloads %> скач.</span>
                            </div>
                            <a href="/premium/pdfs/<%= mat.id %>/download" class="btn btn-sm btn-primary pdf-dl-btn">
                                <i class="fas fa-download me-1"></i>Скачать
                            </a>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    <% } %>
</div>
