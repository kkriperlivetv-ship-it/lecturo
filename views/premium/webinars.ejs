<style>
    .premium-page-title { margin-bottom: 0.4rem; }
    .premium-page-sub { color: var(--text-secondary); margin-bottom: 2rem; }

    .premium-lock {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        margin-top: 2rem;
    }
    .premium-lock-icon {
        font-size: 3.5rem;
        margin-bottom: 1.25rem;
        background: linear-gradient(135deg, #a855f7, #6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
    }
    .premium-lock h2 { font-size: 1.5rem; margin-bottom: 0.6rem; }
    .premium-lock p { color: var(--text-secondary); max-width: 480px; margin: 0 auto 1.75rem; }

    .wb-cats { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.75rem; }
    .wb-cat-btn {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-secondary);
        font-size: 0.85rem;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }
    .wb-cat-btn:hover, .wb-cat-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }

    .wb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
    .wb-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.15s;
    }
    .wb-card:hover { border-color: var(--accent); }

    .wb-thumb {
        height: 170px;
        background: linear-gradient(135deg, #312e81, #1e1b4b);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .wb-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .wb-thumb-placeholder { font-size: 2.5rem; color: rgba(255,255,255,0.3); }
    .wb-duration-badge {
        position: absolute;
        bottom: 8px;
        right: 10px;
        background: rgba(0,0,0,0.7);
        color: #fff;
        font-size: 0.78rem;
        padding: 2px 8px;
        border-radius: 4px;
    }

    .wb-body { padding: 1rem; flex: 1; display: flex; flex-direction: column; }
    .wb-cat-tag {
        font-size: 0.75rem;
        color: var(--accent);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.4rem;
    }
    .wb-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.4rem; line-height: 1.3; }
    .wb-meta { font-size: 0.82rem; color: var(--text-secondary); flex: 1; }
    .wb-meta span { margin-right: 0.75rem; }
    .wb-actions { display: flex; gap: 0.5rem; margin-top: 0.9rem; }

    .wb-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-secondary);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }
    .wb-empty i { font-size: 2.5rem; margin-bottom: 1rem; display: block; }

    .wb-pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 2rem; flex-wrap: wrap; }
    .wb-page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 0.75rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: var(--bg-secondary);
        color: var(--text-secondary);
        font-size: 0.9rem;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
    }
    .wb-page-btn:hover, .wb-page-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
    }
    .wb-page-btn.disabled { opacity: 0.4; pointer-events: none; }

    /* Modal */
    .wb-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.85);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .wb-modal-overlay.open { display: flex; }
    .wb-modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow-y: auto;
        position: relative;
    }
    .wb-modal-close {
        position: absolute;
        top: 12px;
        right: 14px;
        background: none;
        border: none;
        color: var(--text-secondary);
        font-size: 1.4rem;
        cursor: pointer;
        z-index: 10;
        line-height: 1;
    }
    .wb-modal-close:hover { color: var(--text-primary); }
    .wb-modal-player {
        width: 100%;
        aspect-ratio: 16/9;
        background: #000;
        border-radius: 14px 14px 0 0;
        overflow: hidden;
    }
    .wb-modal-player iframe, .wb-modal-player video {
        width: 100%; height: 100%; border: none;
    }
    .wb-modal-body { padding: 1.25rem 1.5rem 1.5rem; }
    .wb-modal-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.4rem; }
    .wb-modal-meta { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.75rem; }
    .wb-modal-desc { font-size: 0.9rem; color: var(--text-secondary); }
</style>

<div>
    <h1 class="premium-page-title"><i class="fas fa-video me-2" style="color:var(--accent);"></i>Архив вебинаров</h1>
    <p class="premium-page-sub">Записи вебинаров и разборов — смотрите в любое удобное время</p>

    <% if (messages && messages.success) { %><div class="alert alert-success"><%= messages.success %></div><% } %>
    <% if (messages && messages.error) { %><div class="alert alert-danger"><%= messages.error %></div><% } %>

    <% if (!hasAccess) { %>
        <div class="premium-lock">
            <i class="fas fa-video premium-lock-icon"></i>
            <h2>Архив вебинаров — функция Premium</h2>
            <p>Более 400 часов записей вебинаров и разборов доступны только по подписке.</p>
            <a href="/auth/profile" class="btn btn-primary">Получить Premium</a>
        </div>
    <% } else { %>

        <%# Category filter tabs %>
        <div class="wb-cats">
            <a href="/premium/webinars" class="wb-cat-btn <%= currentCategory === 'all' ? 'active' : '' %>">
                Все вебинары <% if (currentCategory === 'all') { %>(<%= total %>)<% } %>
            </a>
            <% categories.forEach(cat => { %>
                <a href="/premium/webinars?category=<%= encodeURIComponent(cat) %>" class="wb-cat-btn <%= currentCategory === cat ? 'active' : '' %>">
                    <%= cat %>
                </a>
            <% }) %>
        </div>

        <% if (webinars.length === 0) { %>
            <div class="wb-empty">
                <i class="fas fa-film"></i>
                <h3>Вебинаров пока нет</h3>
                <p>Скоро здесь появятся записи вебинаров и разборов.</p>
            </div>
        <% } else { %>
            <p style="color:var(--text-secondary); margin-bottom:1.25rem;">Найдено вебинаров: <strong style="color:var(--text-primary);"><%= total %></strong></p>

            <div class="wb-grid">
                <% webinars.forEach(wb => { %>
                    <div class="wb-card">
                        <div class="wb-thumb">
                            <% if (wb.thumbnailUrl) { %>
                                <img src="<%= wb.thumbnailUrl %>" alt="<%= wb.title %>" loading="lazy">
                            <% } else { %>
                                <i class="fas fa-play-circle wb-thumb-placeholder"></i>
                            <% } %>
                            <% if (wb.duration) { %>
                                <span class="wb-duration-badge"><i class="far fa-clock me-1"></i><%= formatDuration(wb.duration) %></span>
                            <% } %>
                        </div>
                        <div class="wb-body">
                            <% if (wb.category) { %><div class="wb-cat-tag"><%= wb.category %></div><% } %>
                            <div class="wb-title"><%= wb.title %></div>
                            <div class="wb-meta">
                                <% if (wb.speaker) { %><span><i class="fas fa-user me-1"></i><%= wb.speaker %></span><% } %>
                                <span><i class="far fa-calendar me-1"></i><%= new Date(wb.date).toLocaleDateString('ru-RU') %></span>
                                <% if (wb.views > 0) { %><span><i class="fas fa-eye me-1"></i><%= wb.views %></span><% } %>
                            </div>
                            <div class="wb-actions">
                                <button class="btn btn-primary btn-sm" onclick="openWebinar(this)"
                                    data-id="<%= wb.id %>"
                                    data-title="<%= (wb.title || '').replace(/'/g, '&#39;') %>"
                                    data-desc="<%= ((wb.description || '').replace(/'/g, '&#39;').substring(0, 300)) %>"
                                    data-speaker="<%= (wb.speaker || '').replace(/'/g, '&#39;') %>"
                                    data-date="<%= new Date(wb.date).toLocaleDateString('ru-RU') %>"
                                    data-duration="<%= formatDuration(wb.duration) %>"
                                    data-url="<%= (wb.videoUrl || '').replace(/'/g, '&#39;') %>">
                                    <i class="fas fa-play me-1"></i>Смотреть
                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <%# Pagination %>
            <% if (totalPages > 1) { %>
                <div class="wb-pagination">
                    <a href="/premium/webinars?category=<%= currentCategory %>&page=<%= page - 1 %>" class="wb-page-btn <%= page <= 1 ? 'disabled' : '' %>">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                    <% for (let p = 1; p <= totalPages; p++) { %>
                        <a href="/premium/webinars?category=<%= currentCategory %>&page=<%= p %>" class="wb-page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
                    <% } %>
                    <a href="/premium/webinars?category=<%= currentCategory %>&page=<%= page + 1 %>" class="wb-page-btn <%= page >= totalPages ? 'disabled' : '' %>">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            <% } %>
        <% } %>
    <% } %>
</div>

<%# Webinar Watch Modal %>
<div class="wb-modal-overlay" id="wbModal" onclick="closeWebinarModal(event)">
    <div class="wb-modal">
        <button class="wb-modal-close" onclick="closeWebinarModal()"><i class="fas fa-times"></i></button>
        <div class="wb-modal-player" id="wbPlayer"></div>
        <div class="wb-modal-body">
            <div class="wb-modal-title" id="wbModalTitle"></div>
            <div class="wb-modal-meta" id="wbModalMeta"></div>
            <div class="wb-modal-desc" id="wbModalDesc"></div>
        </div>
    </div>
</div>

<script>
function getYouTubeId(url) {
    if (!url) return null;
    const m = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
    return m ? m[1] : null;
}

function openWebinar(btn) {
    const videoUrl = btn.dataset.url;
    const title = btn.dataset.title;
    const desc = btn.dataset.desc;
    const speaker = btn.dataset.speaker;
    const date = btn.dataset.date;
    const duration = btn.dataset.duration;

    document.getElementById('wbModalTitle').textContent = title;
    const metaParts = [];
    if (speaker) metaParts.push('<i class="fas fa-user me-1"></i>' + escHtml(speaker));
    if (date) metaParts.push('<i class="far fa-calendar me-1"></i>' + escHtml(date));
    if (duration) metaParts.push('<i class="far fa-clock me-1"></i>' + escHtml(duration));
    document.getElementById('wbModalMeta').innerHTML = metaParts.join(' &nbsp;·&nbsp; ');
    document.getElementById('wbModalDesc').textContent = desc;

    const player = document.getElementById('wbPlayer');
    const ytId = getYouTubeId(videoUrl);
    if (ytId) {
        player.innerHTML = `<iframe src="https://www.youtube.com/embed/${ytId}?autoplay=1" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
    } else if (videoUrl) {
        player.innerHTML = `<video controls autoplay src="${escHtml(videoUrl)}" style="width:100%;height:100%;"></video>`;
    } else {
        player.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#fff;">Видео недоступно</div>';
    }

    document.getElementById('wbModal').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeWebinarModal(e) {
    if (e && e.target !== document.getElementById('wbModal')) return;
    document.getElementById('wbModal').classList.remove('open');
    document.getElementById('wbPlayer').innerHTML = '';
    document.body.style.overflow = '';
}

function escHtml(str) {
    return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeWebinarModal();
});
</script>
