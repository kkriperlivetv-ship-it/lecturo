<script>
    function toggleRules() {
        console.log('toggleRules called');
        const toggleButton = document.getElementById('rulesToggle');
        const rulesContainer = document.getElementById('rulesContainer');
        if (!toggleButton || !rulesContainer) return;
        
        const isExpanded = rulesContainer.classList.contains('expanded');
        console.log('isExpanded:', isExpanded);
        
        if (isExpanded) {
            rulesContainer.classList.remove('expanded');
            toggleButton.classList.remove('expanded');
            toggleButton.innerHTML = '<i class="fas fa-chevron-down"></i> Показать правила';
        } else {
            rulesContainer.classList.add('expanded');
            toggleButton.classList.add('expanded');
            toggleButton.innerHTML = '<i class="fas fa-chevron-up"></i> Скрыть правила';
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOMContentLoaded for rules triggered');
        const toggleButton = document.getElementById('rulesToggle');
        if (toggleButton) {
            toggleButton.onclick = toggleRules;
            console.log('onclick assigned');
        }
    });
</script>
