<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Сброс пароля</h2>
        
        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>
        
        <% if (success) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> <%= success %>
            </div>
            <div class="auth-links">
                <a href="/auth/login" class="btn btn-primary btn-block">Перейти ко входу</a>
            </div>
        <% } else { %>
            <% if (token) { %>
                <p class="auth-subtitle">Введите новый пароль для вашего аккаунта.</p>
                <form method="POST" action="/auth/reset/<%= token %>" class="auth-form">
                    <div class="form-group">
                        <label for="password">Новый пароль</label>
                        <input type="password" id="password" name="password" required placeholder="Минимум 6 символов">
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Подтвердите пароль</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Повторите пароль">
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Сменить пароль</button>
                </form>
            <% } else { %>
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> Недействительная ссылка для сброса пароля.
                </div>
                <div class="auth-links">
                    <a href="/auth/forgot" class="btn btn-outline">Запросить новую ссылку</a>
                    <a href="/auth/login" class="btn btn-outline">Вернуться ко входу</a>
                </div>
            <% } %>
        <% } %>
        
        <% if (!success) { %>
            <div class="auth-links">
                <a href="/auth/login" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Вернуться ко входу
                </a>
                <a href="/" class="btn btn-outline">
                    <i class="fas fa-home"></i> На главную
                </a>
            </div>
        <% } %>
    </div>
</div>