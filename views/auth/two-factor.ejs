<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Подтверждение входа</h2>
        <p class="auth-subtitle">Введите 6-значный код из приложения-аутентификатора для <strong><%= email %></strong>.</p>

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/auth/2fa" class="auth-form">
            <div class="form-group">
                <label for="token">Код подтверждения</label>
                <input type="text" id="token" name="token" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required placeholder="123456">
            </div>
            <button type="submit" class="btn btn-primary btn-block">Подтвердить вход</button>
        </form>

        <div class="auth-links">
            <p class="auth-link"><a href="/auth/login">Вернуться ко входу</a></p>
        </div>
    </div>
</div>
