<div class="admin-page-container">
    <div class="admin-header">
        <h1 class="admin-title">Админ-панель</h1>
        
        <% if (messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        
        <% if (messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= messages.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
    </div>
    
    <div class="admin-stats-grid">
        <div class="admin-card card-users">
            <div class="card-content">
                <h3 class="card-title">Пользователи</h3>
                <p class="card-count"><%= usersCount %></p>
                <a href="/admin/users" class="card-button">Управление</a>
            </div>
        </div>
        
        <div class="admin-card card-courses">
            <div class="card-content">
                <h3 class="card-title">Курсы</h3>
                <p class="card-count"><%= coursesCount %></p>
                <a href="/admin/courses" class="card-button">Управление</a>
            </div>
        </div>
        
        <div class="admin-card card-logs">
            <div class="card-content">
                <h3 class="card-title">Логи действий</h3>
                <p class="card-count"><%= logsCount %></p>
                <a href="/admin/logs" class="card-button">Просмотр</a>
            </div>
        </div>

        <div class="admin-card" style="background:linear-gradient(135deg,rgba(168,85,247,0.15),rgba(99,102,241,0.15));border:1px solid rgba(168,85,247,0.3);">
            <div class="card-content">
                <h3 class="card-title"><i class="fas fa-crown me-1" style="color:#a855f7;"></i>Premium-контент</h3>
                <p style="font-size:0.85rem;color:var(--text-secondary);margin:0.25rem 0 1rem;">Вебинары и PDF-материалы</p>
                <a href="/admin/premium" class="card-button">Управление</a>
            </div>
        </div>
    </div>
</div>