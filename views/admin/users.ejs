<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="admin-block">
                <div class="admin-block-header">
                    <div>
                        <h1 class="admin-block-title">Управление пользователями</h1>
                        <p class="admin-block-subtitle">Всего пользователей: <span class="badge bg-primary fs-6"><%= users.length %></span></p>
                    </div>
                    <a href="/admin" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Назад в админ-панель
                    </a>
                </div>

                <% if (messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                
                <% if (messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="admin-block-content">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Имя пользователя</th>
                                    <th>Email</th>
                                    <th>Роль</th>
                                    <th>Дата регистрации</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user => { %>
                                    <tr>
                                        <td><%= user.id %></td>
                                        <td><strong><%= user.username %></strong>
                                            <% if (user.isProtected) { %>
                                                <span class="badge bg-dark ms-1" title="Защищённый пользователь (нельзя удалить/изменить)">
                                                    <i class="fas fa-shield-alt"></i> Защищён
                                                </span>
                                            <% } %>
                                        </td>
                                        <td><%= user.email %></td>
                                        <td>
                                            <% if (user.role === 'owner') { %>
                                                <span class="badge bg-purple">
                                                    <i class="fas fa-crown"></i> Владелец
                                                </span>
                                            <% } else if (user.role === 'admin') { %>
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-user-shield"></i> Администратор
                                                </span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-user"></i> Пользователь
                                                </span>
                                            <% } %>
                                        </td>
                                        <td><%= new Date(user.createdAt).toLocaleDateString('ru-RU') %></td>
                                        <td>
                                            <% if (!user.isProtected) {
                                                if (user.role === 'user') { %>
                                                    <form action="/admin/users/<%= user.id %>/role" method="POST" class="d-inline">
                                                        <input type="hidden" name="role" value="admin">
                                                        <button type="submit" class="btn btn-sm btn-success"
                                                                onclick="return confirm('Назначить пользователя <%= user.username %> администратором?')">
                                                            <i class="fas fa-user-shield me-1"></i>Сделать админом
                                                        </button>
                                                    </form>
                                                <% } else if (user.role === 'admin') { %>
                                                    <form action="/admin/users/<%= user.id %>/role" method="POST" class="d-inline">
                                                        <input type="hidden" name="role" value="user">
                                                        <button type="submit" class="btn btn-sm btn-warning"
                                                                onclick="return confirm('Убрать права администратора у <%= user.username %>?')">
                                                            <i class="fas fa-user me-1"></i>Убрать админа
                                                        </button>
                                                    </form>
                                                <% }
                                            } else { %>
                                                <span class="text-muted small">Защищён</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    
                    <% if (users.length === 0) { %>
                        <div class="text-center py-5">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <h5>Пользователи не найдены</h5>
                            <p class="text-muted">В системе пока нет зарегистрированных пользователей.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>