<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="admin-block">
                <div class="admin-block-header">
                    <div>
                        <h1 class="admin-block-title">Управление курсами</h1>
                        <p class="admin-block-subtitle">Всего курсов: <span class="badge bg-primary fs-6"><%= courses.length %></span></p>
                    </div>
                    <a href="/admin" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Назад в админ-панель
                    </a>
                </div>

                <% if (messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                
                <% if (messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <div class="admin-block-content">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Название</th>
                                    <th>Жанр</th>
                                    <th>Автор</th>
                                    <th>Длительность</th>
                                    <th>Дата создания</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% courses.forEach(course => { %>
                                    <tr>
                                        <td><%= course.id %></td>
                                        <td>
                                            <strong><%= course.title %></strong>
                                            <div class="text-muted small mt-1" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                <%= course.description %>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-info"><%= course.genre %></span>
                                        </td>
                                        <td>
                                            <div><%= course.User.username %></div>
                                            <div class="text-muted small"><%= course.User.email %></div>
                                        </td>
                                        <td><%= course.totalTime %> мин.</td>
                                        <td><%= new Date(course.createdAt).toLocaleDateString('ru-RU') %></td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="/courses/<%= course.id %>" class="btn btn-sm btn-outline-primary" target="_blank">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <form action="/admin/courses/<%= course.id %>/delete" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Вы уверены, что хотите удалить курс \'<%= course.title %>\'? Это действие нельзя отменить.')">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    
                    <% if (courses.length === 0) { %>
                        <div class="text-center py-5">
                            <i class="fas fa-book fa-3x text-muted mb-3"></i>
                            <h5>Курсы не найдены</h5>
                            <p class="text-muted">В системе пока нет созданных курсов.</p>
                            <a href="/courses/create" class="btn btn-primary">
                                <i class="fas fa-plus me-2"></i>Создать первый курс
                            </a>
                        </div>
                    <% } %>
                </div>

                <div class="mt-4 pt-4 border-top border-2A2D30">
                    <div class="alert alert-warning mb-0">
                        <h5 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>Внимание!</h5>
                        <p class="mb-0">
                            Удаление курсов является необратимым действием. При удалении курса также будут удалены все связанные с ним уроки.
                            Администратор может удалять любые курсы, включая созданные другими пользователями.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>