<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Lecturo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <!-- Bootstrap 5 CSS -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dot-field.css">
    <link rel="stylesheet" href="/font-awesome/css/all.min.css">
</head>
<body class="<%= (typeof admin !== 'undefined' && admin) ? 'admin-page' : '' %>">
    <div id="global-dot-field"
         data-dot-field
         data-dot-radius="1.5"
         data-dot-spacing="14"
         data-bulge-strength="67"
         data-glow-radius="160"
         data-sparkle="false"
         data-wave-amplitude="0"
         data-gradient-from="rgba(168, 85, 247, 0.35)"
         data-gradient-to="rgba(180, 151, 207, 0.25)"
         data-glow-color="#120F17">
    </div>
    <%- include('partials/header') %>
    <main class="container">
        <%- body %>
    </main>
    <%- include('partials/footer') %>
    <!-- Bootstrap 5 JS Bundle with Popper -->
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/blur-text.js" defer></script>
    <script src="/js/dot-field.js"></script>
</body>
</html>